<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Súper Manual de Recaudos - Finaxis Consultoría Experta</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts: Outfit (Apple-style) -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Mermaid.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
    <style>
        :root {
            --apple-bg: #F5F5F7;
            --apple-card: #FFFFFF;
            --apple-accent: #0071E3;
            --apple-indigo: #6366F1;
            --apple-violet: #8B5CF6;
        }
        body { 
            font-family: 'Outfit', sans-serif; 
            background-color: var(--apple-bg);
            color: #1D1D1F;
        }
        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-right: 1px solid rgba(0, 0, 0, 0.1);
        }
        .mermaid { 
            background: #FFFFFF; 
            border-radius: 24px; 
            padding: 2.5rem; 
            margin: 2.5rem 0; 
            box-shadow: 0 10px 40px rgba(0,0,0,0.03); 
            border: 1px solid rgba(0,0,0,0.05);
            display: flex;
            justify-content: center;
        }
        .markdown-body h1 { 
            font-size: 3.5rem; 
            font-weight: 800; 
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, #4F46E5 0%, #9333EA 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 2rem;
        }
        .markdown-body h2 { 
            font-size: 2.25rem; 
            font-weight: 700; 
            color: #1D1D1F; 
            margin-top: 4rem; 
            margin-bottom: 1.5rem;
            letter-spacing: -0.01em;
        }
        .markdown-body h3 { 
            font-size: 1.5rem; 
            font-weight: 600; 
            color: #334155; 
            margin-top: 2.5rem; 
            margin-bottom: 1rem;
        }
        .markdown-body p { 
            font-size: 1.25rem; 
            line-height: 1.65; 
            color: #4B5563; 
            margin-bottom: 1.5rem;
        }
        .markdown-body ul { 
            list-style: none;
            padding-left: 0;
            margin-bottom: 2rem;
        }
        .markdown-body li {
            font-size: 1.25rem;
            color: #4B5563;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: flex-start;
            gap: 14px;
        }
        .markdown-body li::before {
            content: "•";
            color: var(--apple-accent);
            font-weight: bold;
            font-size: 1.5rem;
            line-height: 1;
        }
        .premium-card {
            background: var(--apple-card);
            border-radius: 32px;
            padding: 3.5rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.03);
            border: 1px solid rgba(0,0,0,0.04);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            margin-bottom: 3rem;
        }
        .premium-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 30px 80px rgba(0,0,0,0.06);
        }
        .consultancy-note {
            background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
            border-left: 6px solid var(--apple-accent);
            padding: 2.5rem;
            border-radius: 24px;
            margin: 3.5rem 0;
        }
        .sidebar-item {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .sidebar-item-active {
            background: #FFFFFF;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            color: var(--apple-accent) !important;
            transform: translateX(8px);
        }
        .chapter-content {
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .chapter-content.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .dot-active {
            width: 32px;
            background: var(--apple-accent);
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 10px; }
    </style>
</head>
<body class="transition-all duration-500 overflow-hidden">

    <div class="flex h-screen">
        <!-- Sidebar Navigation -->
        <aside class="w-[400px] glass h-full flex flex-col z-20">
            <div class="p-12">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-12 h-12 bg-gradient-to-br from-blue-600 to-indigo-600 rounded-2xl flex items-center justify-center shadow-xl shadow-blue-100">
                        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    </div>
                    <div>
                        <h1 class="text-2xl font-bold tracking-tight text-gray-900 m-0 leading-none" style="background:none; -webkit-text-fill-color: initial;">Súper Manual</h1>
                        <p class="text-xs font-bold text-blue-500 uppercase tracking-[0.2em] mt-1">Estrategia & Operación</p>
                    </div>
                </div>
                <p class="text-sm text-gray-400 font-medium leading-relaxed">Arquitectura de Consultoría diseñada para modelar realidades de negocio complejas.</p>
            </div>

            <nav class="flex-1 px-8 space-y-3 overflow-y-auto pb-10">
                <button onclick="showChapter(1)" id="btn-cap-1" class="sidebar-item w-full text-left px-7 py-5 rounded-[24px] text-[15px] font-bold text-gray-400 hover:text-gray-900 transition-all flex items-center justify-between group sidebar-item-active">
                    <span>1. La Filosofía del Sistema</span>
                    <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                </button>
                <button onclick="showChapter(2)" id="btn-cap-2" class="sidebar-item w-full text-left px-7 py-5 rounded-[24px] text-[15px] font-bold text-gray-400 hover:text-gray-900 transition-all flex items-center justify-between group">
                    <span>2. Inventario Físico</span>
                    <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                </button>
                <button onclick="showChapter(3)" id="btn-cap-3" class="sidebar-item w-full text-left px-7 py-5 rounded-[24px] text-[15px] font-bold text-gray-400 hover:text-gray-900 transition-all flex items-center justify-between group">
                    <span>3. El Cerebro Lógico</span>
                    <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                </button>
                <button onclick="showChapter(4)" id="btn-cap-4" class="sidebar-item w-full text-left px-7 py-5 rounded-[24px] text-[15px] font-bold text-gray-400 hover:text-gray-900 transition-all flex items-center justify-between group">
                    <span>4. La Sinfonía Financiera</span>
                    <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                </button>
                <button onclick="showChapter(5)" id="btn-cap-5" class="sidebar-item w-full text-left px-7 py-5 rounded-[24px] text-[15px] font-bold text-gray-400 hover:text-gray-900 transition-all flex items-center justify-between group">
                    <span>5. Masterclass: La Unidad</span>
                    <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                </button>
                <button onclick="showChapter(6)" id="btn-cap-6" class="sidebar-item w-full text-left px-7 py-5 rounded-[24px] text-[15px] font-bold bg-blue-50/50 text-blue-600 hover:text-blue-900 transition-all flex items-center justify-between group border border-blue-100">
                    <span>6. Mapas Lógicos de Negocio</span>
                    <span class="opacity-100 group-hover:translate-x-1 transition-all">✨</span>
                </button>
            </nav>

            <div class="p-12 border-t border-gray-100 flex items-center justify-between">
                <div class="flex items-center gap-2 text-indigo-600 font-bold text-[11px] tracking-widest uppercase">
                    <div class="w-1.5 h-1.5 rounded-full bg-indigo-600 animate-pulse"></div>
                    Online • v.2026.1
                </div>
            </div>
        </aside>

        <!-- Content Area -->
        <main id="contentArea" class="flex-1 overflow-y-auto bg-[#FBFBFD] scroll-smooth">
            <div class="max-w-5xl mx-auto px-20 py-24 markdown-body">
                
                <!-- Capítulo 1 -->
                <section id="cap-1" class="chapter-content block visible">
                    <p class="text-blue-600 font-bold tracking-widest uppercase mb-4 text-xs">Módulo de Recaudos • Capítulo 1</p>
                    <h1 class="text-indigo-600">La Filosofía del Sistema: "Flexibilidad sin Caos"</h1>
                    
                    <div class="premium-card">
                        <p class="text-2xl font-medium text-gray-800 mb-10 leading-snug">"No construimos un software de cobros; construimos un motor de modelado de realidades empresariales."</p>
                        
                        <p>En el mundo de la consultoría de negocios, el mayor error es obligar a la empresa a adaptarse al software. En Finaxis, hemos invertido el paradigma: nuestra plataforma es un lienzo donde usted diseña la conexión exacta de los elementos.</p>
                        
                        <h3>La Conexión de los Elementos</h3>
                        <p>Imagine que el sistema es un juego de piezas inteligentes. Usted tiene <strong>Unidades</strong>, que son la base de todo. Pero una unidad no es solo un número; es el representante de una responsabilidad económica vinculada a un ser humano o empresa.</p>
                    </div>

                    <div class="consultancy-note">
                        <h4 class="text-blue-700 font-bold mb-3 font-sans uppercase tracking-widest text-xs">Escenario Real</h4>
                        <p class="text-blue-900 m-0">Usted puede crear un apartamento y matricularlo en un módulo llamado "Residencial". Pero si crea un local comercial, las reglas cambian. El local no se matricula en el mismo sitio porque sus cobros son distintos. El sistema le permite crear esta "distinción de mundos" sin esfuerzo.</p>
                    </div>
                </section>

                <!-- Capítulo 2 -->
                <section id="cap-2" class="chapter-content hidden">
                    <p class="text-blue-600 font-bold tracking-widest uppercase mb-4 text-xs">Estructura • Capítulo 2</p>
                    <h1 class="text-indigo-600">El Inventario: El Cuerpo Físico y su Distribución</h1>
                    <div class="premium-card">
                        <p class="text-xl font-medium text-gray-700 mb-8">"Para cobrar con precisión, primero debemos mapear la realidad con exactitud."</p>
                        <h2>La Unidad: El Átomo de Facturación</h2>
                        <p>La Unidad representa un <strong>punto de recaudo</strong>. Puede ser una casa, un local, un alumno o incluso un bus de transporte público.</p>
                        <h3>Distribución en Torres y Bloques</h3>
                        <p>Las <strong>Torres</strong> (o Bloques/Zonas) permiten segmentar por estructura física. Esto es vital para la **Discriminación de Gastos**: si se rompe un tubo en la Torre 2, el sistema permite cargar ese gasto exclusivamente a sus propietarios.</p>
                    </div>
                </section>

                <!-- Capítulo 3 -->
                <section id="cap-3" class="chapter-content hidden">
                    <p class="text-blue-600 font-bold tracking-widest uppercase mb-4 text-xs">Lógica • Capítulo 3</p>
                    <h1 class="text-indigo-600">Módulos: El Cerebro Lógico del Recaudo</h1>
                    <div class="premium-card">
                        <p class="text-xl font-medium text-gray-700 mb-8">"La diferencia entre lo ordinario y lo extraordinario es la capacidad de segmentar reglas de negocio."</p>
                        <p>El sistema permite que cada unidad se suscriba a diferentes **Módulos de Contribución**. Estos módulos son los que realmente dictan quién paga qué.</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-8">
                            <div class="p-10 bg-blue-50/50 rounded-3xl border border-blue-100">
                                <h4 class="text-xl font-bold text-blue-700 mb-3 text-sm uppercase tracking-wider">Distribución Fija</h4>
                                <p class="text-gray-600 text-[15px]">Ideal para conceptos uniformes como seguridad o limpieza básica.</p>
                            </div>
                            <div class="p-10 bg-indigo-50/50 rounded-3xl border border-indigo-100">
                                <h4 class="text-xl font-bold text-indigo-700 mb-3 text-sm uppercase tracking-wider">Distribución Proporcional</h4>
                                <p class="text-gray-600 text-[15px]">Paga según participación (Coeficiente). Fundamental para cuotas de administración.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Capítulo 4 -->
                <section id="cap-4" class="chapter-content hidden">
                    <p class="text-blue-600 font-bold tracking-widest uppercase mb-4 text-xs">Finanzas • Capítulo 4</p>
                    <h1 class="text-indigo-600">La Sinfonía Financiera: Conceptos y Ejecución</h1>
                    <div class="premium-card">
                        <p>Los conceptos no se asignan a las unidades directamente, sino a **Módulos**. Esto permite que un cambio en un valor afecte a miles de unidades con un solo clic.</p>
                        <h3>Automatización Inteligente</h3>
                        <ul>
                            <li><strong>Intereses de Mora:</strong> Configuración automática por política.</li>
                            <li><strong>Cruce de Anticipos:</strong> Detección de saldos a favor (Cuenta 2805) y cruce automático contra deuda (Cuenta 1305).</li>
                        </ul>
                    </div>
                </section>

                <!-- Capítulo 5 -->
                <section id="cap-5" class="chapter-content hidden">
                    <p class="text-blue-600 font-bold tracking-widest uppercase mb-4 text-xs">Operación • Capítulo 5</p>
                    <h1 class="text-indigo-600">Masterclass: El Ciclo de Vida de la Unidad</h1>
                    <div class="premium-card">
                        <h2>El Vínculo Legal (Terceros)</h2>
                        <p>La deuda pertenece a un ser humano o entidad. El vínculo con el módulo de Terceros es obligatorio para asegurar la cobrabilidad legal.</p>
                        <h2>Datos de Convivencia</h2>
                        <p>La unidad integra también el control de <strong>Vehículos</strong> (placas, marcas) y <strong>Mascotas</strong>, permitiendo una gestión 360° de la administración.</p>
                    </div>
                </section>

                <!-- Capítulo 6: MAPAS LÓGICOS (EL NUEVO CAPÍTULO) -->
                <section id="cap-6" class="chapter-content hidden">
                    <p class="text-blue-600 font-bold tracking-widest uppercase mb-4 text-xs">Visualización Maestro • Capítulo 6</p>
                    <h1 class="text-indigo-600">Mapas Lógicos de Negocio</h1>
                    
                    <div class="premium-card">
                        <p class="text-xl font-medium text-gray-700 mb-10">"Un gráfico vale más que mil palabras cuando se trata de entender la arquitectura del dinero."</p>

                        <h2 class="text-2xl">1. El Mapa del Corazón (Estructura de Recaudo)</h2>
                        <p>Este mapa ilustra el flujo de inteligencia desde la configuración de reglas hasta el documento final. Es el **gráfico estratégico esencial** para entender cómo el sistema amalgama la lógica de negocio.</p>
                        
                        <div class="mermaid">
                        graph TD
                            C[Conceptos de Cobro] -->|Configuran REGLAS| M[Módulos de Contribución]
                            T[Torres / Bloques] -->|Agrupan FÍSICAMENTE| U{Unidades de Cobro}
                            M -->|Agrupan LÓGICAMENTE| U
                            U -->|Generan| F[Factura Masiva]
                            
                            style C fill:#4F46E5,color:#fff
                            style M fill:#818CF8,color:#fff
                            style T fill:#C7D2FE,color:#1D1D1F
                            style U fill:#EEF2FF,stroke:#4F46E5,stroke-width:2px
                            style F fill:#10B981,color:#fff
                        </div>

                        <h2 class="text-2xl mt-16">2. Jerarquía de Ejecución (Macro a Micro)</h2>
                        <p>Cómo fluyen las decisiones del administrador hacia las unidades finales segmentando por naturaleza comercial o residencial.</p>

                        <div class="mermaid">
                        graph LR
                            subgraph "Estrategia"
                                D[Políticas de Empresa]
                            end
                            subgraph "Táctica (Módulos)"
                                D --> M1[Residencial]
                                D --> M2[Comercial]
                                D --> M3[Educación]
                            end
                            subgraph "Operación (Unidades)"
                                M1 --> U1[Apto 101]
                                M2 --> U2[Local 5]
                                M3 --> U3[Alumno 01]
                            end
                            style D fill:#6366F1,color:#fff
                            style M1 fill:#EEF2FF
                            style M2 fill:#EEF2FF
                            style M3 fill:#EEF2FF
                        </div>

                        <h2 class="text-2xl mt-16">3. El Ciclo de Integridad Financiera</h2>
                        <p>La conexión inquebrantable entre la deuda, el pago y la contabilidad patrimonial.</p>

                        <div class="mermaid">
                        flowchart TD
                            A[Facturación Masiva] --> B[Cartera (1305)]
                            C[Recibo de Caja] --> D[Cruce de Anticipos (2805)]
                            D --> B
                            B --> E[Balance en Tiempo Real]
                            style A fill:#4F46E5,color:#fff
                            style C fill:#10B981,color:#fff
                            style E fill:#F97316,color:#fff
                        </div>

                        <div class="consultancy-note mt-12">
                            <strong>Nota de Consultoría:</strong><br>
                            Use estos mapas para capacitar a su equipo. Cuando todos entienden que la unidad es el receptor de una **doble agrupación** (Física y Lógica), los errores de parametrización desaparecen.
                        </div>
                    </div>
                </section>

                <!-- Footer Navigation -->
                <div class="mt-24 pt-12 border-t border-gray-100 flex justify-between items-center bg-white/40 p-10 rounded-[40px] shadow-sm">
                    <button id="prevBtn" onclick="changeStep(-1)" class="px-8 py-4 bg-white border border-gray-100 rounded-2xl text-md font-bold text-gray-300 transition-all opacity-50 cursor-not-allowed">Anterior</button>
                    
                    <div id="stepDots" class="flex gap-3">
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 dot-active cursor-pointer" onclick="showChapter(1)"></div>
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 cursor-pointer" onclick="showChapter(2)"></div>
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 cursor-pointer" onclick="showChapter(3)"></div>
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 cursor-pointer" onclick="showChapter(4)"></div>
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 cursor-pointer" onclick="showChapter(5)"></div>
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 cursor-pointer" onclick="showChapter(6)"></div>
                    </div>

                    <button id="nextBtn" onclick="changeStep(1)" class="px-10 py-4 bg-indigo-600 text-white rounded-2xl text-md font-bold hover:bg-indigo-700 shadow-xl shadow-indigo-100 transition-all">Siguiente Capítulo</button>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Inicializar Mermaid con tema moderno
        mermaid.initialize({ 
            startOnLoad: true, 
            theme: 'base', 
            themeVariables: {
                primaryColor: '#EEF2FF',
                primaryTextColor: '#4F46E5',
                primaryBorderColor: '#4F46E5',
                lineColor: '#6366F1',
                secondaryColor: '#F8FAFC',
                tertiaryColor: '#FFFFFF',
                fontFamily: 'Outfit'
            },
            securityLevel: 'loose' 
        });

        let currentChapter = 1;
        const TOTAL_CHAPTERS = 6;

        function showChapter(n) {
            // Animación suave de salida
            document.querySelectorAll('.chapter-content').forEach(el => {
                el.classList.add('hidden');
                el.classList.remove('block', 'visible');
            });
            
            // Mostrar nuevo capítulo con retardo para animación
            setTimeout(() => {
                const target = document.getElementById(`cap-${n}`);
                if (target) {
                    target.classList.remove('hidden');
                    target.classList.add('block');
                    setTimeout(() => target.classList.add('visible'), 50);
                }
            }, 300);
            
            // Actualizar Sidebar
            document.querySelectorAll('.sidebar-item').forEach((el, index) => {
                if (index === n-1) {
                    el.classList.add('sidebar-item-active');
                    el.classList.replace('text-gray-400', 'text-gray-900');
                } else {
                    el.classList.remove('sidebar-item-active');
                    if (!el.id.includes('6')) el.classList.add('text-gray-400');
                }
            });

            // Actualizar Dots
            document.querySelectorAll('#stepDots .dot').forEach((el, index) => {
                if (index === n-1) {
                    el.classList.add('dot-active');
                } else {
                    el.classList.remove('dot-active');
                }
            });

            // Actualizar botones de pie
            const prev = document.getElementById('prevBtn');
            const next = document.getElementById('nextBtn');
            
            prev.className = `px-8 py-4 bg-white border border-gray-200 rounded-2xl text-md font-bold transition-all ${n === 1 ? 'opacity-50 cursor-not-allowed text-gray-200' : 'hover:bg-gray-100 text-gray-700 shadow-sm'}`;
            next.innerText = n === TOTAL_CHAPTERS ? 'Finalizar' : 'Siguiente';
            next.className = `px-10 py-4 ${n === TOTAL_CHAPTERS ? 'bg-green-600 hover:bg-green-700' : 'bg-indigo-600 hover:bg-indigo-700'} text-white rounded-2xl text-md font-bold shadow-xl shadow-indigo-100 transition-all`;
            next.onclick = n === TOTAL_CHAPTERS ? () => window.close() : () => changeStep(1);

            currentChapter = n;
            document.getElementById('contentArea').scrollTo({ top: 0, behavior: 'smooth' });
            
            // Re-render Mermaid diagrams for the visible section
            mermaid.init(undefined, '.chapter-content.visible .mermaid');
        }

        function changeStep(dir) {
            let next = currentChapter + dir;
            if (next >= 1 && next <= TOTAL_CHAPTERS) {
                showChapter(next);
            }
        }

        // Initialize first chapter
        window.onload = () => showChapter(1);
    </script>
</body>
</html>
