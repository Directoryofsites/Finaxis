<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Súper Manual de Recaudos - Finaxis Consultoría Experta</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts: Outfit (Apple-style) -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Mermaid.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
    <style>
        :root {
            --apple-bg: #F5F5F7;
            --apple-card: #FFFFFF;
            --apple-accent: #0071E3;
            --apple-indigo: #6366F1;
            --apple-violet: #8B5CF6;
        }
        body { 
            font-family: 'Outfit', sans-serif; 
            background-color: var(--apple-bg);
            color: #1D1D1F;
        }
        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-right: 1px solid rgba(0, 0, 0, 0.1);
        }
        .mermaid { 
            background: #FFFFFF; 
            border-radius: 24px; 
            padding: 2.5rem; 
            margin: 2.5rem 0; 
            box-shadow: 0 10px 40px rgba(0,0,0,0.03); 
            border: 1px solid rgba(0,0,0,0.05);
            display: flex;
            justify-content: center;
        }
        .markdown-body h1 { 
            font-size: 3rem; 
            font-weight: 800; 
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, #4F46E5 0%, #9333EA 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 2rem;
            line-height: 1.1;
        }
        .markdown-body h2 { 
            font-size: 2rem; 
            font-weight: 700; 
            color: #1D1D1F; 
            margin-top: 3.5rem; 
            margin-bottom: 1.5rem;
            letter-spacing: -0.01em;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            padding-bottom: 0.5rem;
        }
        .markdown-body h3 { 
            font-size: 1.5rem; 
            font-weight: 600; 
            color: #334155; 
            margin-top: 2.5rem; 
            margin-bottom: 1rem;
        }
        .markdown-body p { 
            font-size: 1.2rem; 
            line-height: 1.65; 
            color: #4B5563; 
            margin-bottom: 1.5rem;
        }
        .markdown-body ul { 
            list-style: none;
            padding-left: 0;
            margin-bottom: 2rem;
        }
        .markdown-body li {
            font-size: 1.15rem;
            color: #4B5563;
            margin-bottom: 1rem;
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }
        .markdown-body li strong {
            color: #1D1D1F;
        }
        .markdown-body li::before {
            content: "•";
            color: var(--apple-accent);
            font-weight: bold;
            font-size: 1.5rem;
            line-height: 1;
        }
        .premium-card {
            background: var(--apple-card);
            border-radius: 32px;
            padding: 3rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.03);
            border: 1px solid rgba(0,0,0,0.04);
            margin-bottom: 3rem;
        }
        .alert {
            padding: 2rem;
            border-radius: 20px;
            margin: 2.5rem 0;
        }
        .alert-tip {
            background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
            border-left: 6px solid #10B981;
        }
        .alert-important {
            background: linear-gradient(135deg, #FFF7ED 0%, #FFEDD5 100%);
            border-left: 6px solid #F97316;
        }
        .sidebar-item {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .sidebar-item-active {
            background: #FFFFFF;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            color: var(--apple-accent) !important;
            transform: translateX(8px);
        }
        .chapter-content {
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .chapter-content.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .dot-active {
            width: 32px;
            background: var(--apple-accent);
        }
        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin: 2rem 0;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid rgba(0,0,0,0.05);
        }
        th {
            background: #F9FAFB;
            padding: 1.25rem;
            text-align: left;
            font-weight: 700;
            color: #1D1D1F;
        }
        td {
            padding: 1.25rem;
            border-top: 1px solid rgba(0,0,0,0.05);
            color: #4B5563;
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 10px; }
    </style>
</head>
<body class="transition-all duration-500 overflow-hidden">

    <div class="flex h-screen">
        <!-- Sidebar Navigation -->
        <aside class="w-[380px] glass h-full flex flex-col z-20">
            <div class="p-12">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-12 h-12 bg-gradient-to-br from-indigo-600 to-blue-600 rounded-2xl flex items-center justify-center shadow-xl shadow-blue-100">
                        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    </div>
                    <div>
                        <h1 class="text-2xl font-bold tracking-tight text-gray-900 m-0 leading-none">Súper Manual</h1>
                        <p class="text-[10px] font-extrabold text-blue-500 uppercase tracking-[0.2em] mt-1">Consultoría de Negocio</p>
                    </div>
                </div>
            </div>

            <nav class="flex-1 px-8 space-y-2 overflow-y-auto pb-10">
                <button onclick="showChapter(1)" id="btn-cap-1" class="sidebar-item w-full text-left px-6 py-4 rounded-[20px] text-[15px] font-bold text-gray-400 hover:text-gray-900 transition-all flex items-center justify-between group sidebar-item-active">
                    <span>1. Panorama General</span>
                    <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                </button>
                <button onclick="showChapter(2)" id="btn-cap-2" class="sidebar-item w-full text-left px-6 py-4 rounded-[20px] text-[15px] font-bold text-gray-400 hover:text-gray-900 transition-all flex items-center justify-between group">
                    <span>2. Inventario Físico</span>
                    <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                </button>
                <button onclick="showChapter(3)" id="btn-cap-3" class="sidebar-item w-full text-left px-6 py-4 rounded-[20px] text-[15px] font-bold text-gray-400 hover:text-gray-900 transition-all flex items-center justify-between group">
                    <span>3. Lógica de Segmentación</span>
                    <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                </button>
                <button onclick="showChapter(4)" id="btn-cap-4" class="sidebar-item w-full text-left px-6 py-4 rounded-[20px] text-[15px] font-bold text-gray-400 hover:text-gray-900 transition-all flex items-center justify-between group">
                    <span>4. Articulación Maestra</span>
                    <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                </button>
                <button onclick="showChapter(5)" id="btn-cap-5" class="sidebar-item w-full text-left px-6 py-4 rounded-[20px] text-[15px] font-bold text-gray-400 hover:text-gray-900 transition-all flex items-center justify-between group">
                    <span>5. Ciclo de Vida: La Unidad</span>
                    <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                </button>
                <button onclick="showChapter(6)" id="btn-cap-6" class="sidebar-item w-full text-left px-6 py-4 rounded-[20px] text-[15px] font-bold text-gray-400 hover:text-gray-900 transition-all flex items-center justify-between group">
                    <span>6. Mapas Lógicos Avanzados</span>
                    <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
                </button>
            </nav>

            <div class="p-12 border-t border-gray-100">
                <div class="flex items-center gap-2 text-indigo-600 font-bold text-[11px] tracking-widest uppercase">
                    <div class="w-1.5 h-1.5 rounded-full bg-indigo-600 animate-pulse"></div>
                    Sincronizado • 2026.3
                </div>
            </div>
        </aside>

        <!-- Content Area -->
        <main id="contentArea" class="flex-1 overflow-y-auto bg-[#FBFBFD] scroll-smooth">
            <div class="max-w-4xl mx-auto px-16 py-24 markdown-body">
                
                <!-- Capítulo 1 -->
                <section id="cap-1" class="chapter-content block visible">
                    <h1>Panorama General del Modelo de Recaudos (Recuperación de Cartera)</h1>
                    
                    <div class="premium-card">
                        <h2>1. La Filosofía del Sistema: "Flexibilidad sin Caos"</h2>
                        <p>Nuestra plataforma ha sido diseñada bajo un paradigma de <strong>Consultoría de Negocio</strong>, donde el software no impone una estructura rígida, sino que se convierte en un lienzo para modelar la operación financiera.</p>
                        <h3>¿Qué resolvemos?</h3>
                        <ul>
                            <li><strong>Segmentación Inteligente</strong>: Cobros diferenciados por uso (Residencial vs Comercial).</li>
                            <li><strong>Localización de Gastos</strong>: Discriminación por Torres.</li>
                            <li><strong>Automatización Contable</strong>: Conexión directa con el PUC.</li>
                            <li><strong>Integridad de Cartera</strong>: Cruzado automático de anticipos (Cuenta 2805).</li>
                        </ul>
                    </div>

                    <h2>2. La Arquitectura del Cobro (Panorama de Conexión)</h2>
                    <div class="mermaid">
                    graph TD
                    A[Conceptos de Cobro] -->|Configuran REGLAS| B(Módulos de Contribución)
                    B -->|Agrupan LÓGICAMENTE| C{Unidades de Cobro}
                    D[Torres / Bloques] -->|Agrupan FÍSICAMENTE| C
                    C -->|Generan| E[Factura Masiva]
                    style A fill:#4F46E5,color:#fff
                    style B fill:#818CF8,color:#fff
                    style D fill:#C7D2FE,color:#312E81
                    style E fill:#10B981,color:#fff
                    </div>
                </section>

                <!-- Capítulo 2 -->
                <section id="cap-2" class="chapter-content hidden">
                    <h1>Capítulo 2: El Inventario Físico (Unidades y Torres)</h1>
                    <div class="premium-card">
                        <h2>1. La Unidad: El Centro de Gravedad</h2>
                        <p>La <strong>Unidad</strong> es una <strong>Entidad Financiera Autónoma</strong>. Cada unidad tiene un Propietario (Vínculo Jurídico) y un Coeficiente (Peso Financiero).</p>
                    </div>
                    <h2>2. Gestión de Torres</h2>
                    <p>Las Torres permiten segmentar la infraestructura física para cobros localizados (ej: Arreglo de tubería solo en Torre 4).</p>
                    <div class="mermaid">
                    graph LR
                    subgraph "Físico"
                    T1[Torre 1]
                    T1 --- U1[Apto 101]
                    T1 --- U2[Apto 102]
                    end
                    </div>
                </section>

                <!-- Capítulo 3 -->
                <section id="cap-3" class="chapter-content hidden">
                    <h1>Capítulo 3: Módulos y Conceptos</h1>
                    <div class="premium-card">
                        <h2>Módulos de Contribución</h2>
                        <p>Representan la <strong>Naturaleza del Cobro</strong>. Una unidad puede pertenecer a múltiples módulos (ej: Residencial + Piscina).</p>
                    </div>
                    <div class="mermaid">
                    graph TD
                    C1[Gasto Jardín] --> M1((Módulo Casas))
                    M1 --> U1[Casa 1]
                    M1 --> U2[Casa 2]
                    </div>
                </section>

                <!-- Capítulo 4 -->
                <section id="cap-4" class="chapter-content hidden">
                    <h1>Capítulo 4: Articulación Maestra</h1>
                    <div class="premium-card">
                        <h2>La Sinfonía de la Facturación</h2>
                        <p>El motor de facturación cruza conceptos, módulos y torres para generar documentos impecables.</p>
                    </div>
                    <h2>Gobernanza de Reliquidación</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-8">
                        <div class="premium-card !p-10 border-t-8 border-red-500">
                            <h4 class="font-bold text-red-600 mb-2">BORRAR Y REGENERAR</h4>
                            <p class="text-xs">Uso: Error detectado antes de enviar al residente. Mantiene consecutivos perfectos.</p>
                        </div>
                        <div class="premium-card !p-10 border-t-8 border-indigo-500">
                            <h4 class="font-bold text-indigo-600 mb-2">COMPLETAR (DELTA)</h4>
                            <p class="text-xs">Uso: Facturas ya enviadas. Solo genera lo que falta para no alterar los saldos previos.</p>
                        </div>
                    </div>
                </section>

                <!-- Capítulo 5 -->
                <section id="cap-5" class="chapter-content hidden">
                    <h1>Capítulo 5: El Ciclo de Vida de la Unidad</h1>
                    <div class="premium-card">
                        <h2>1. Creación e Integridad</h2>
                        <p>Al crear una unidad, el sistema exige tres dimensiones obligatorias:</p>
                        <ul>
                            <li><strong>Identificación Física</strong>: Torre y número de unidad.</li>
                            <li><strong>Responsabilidad Jurídica</strong>: Vínculo con el módulo de Terceros (Dueño). Sin esto, no hay cobrabilidad legal.</li>
                            <li><strong>Contribución Económica</strong>: Coeficiente y asignación de Módulos.</li>
                        </ul>
                    </div>
                    
                    <div class="alert alert-important">
                        <h4 class="font-bold text-orange-800 mb-2">Aclaración Estratégica</h4>
                        <p class="text-orange-900 m-0">El campo **"Tipo"** en la ficha es puramente informativo para reportes. Quien realmente **manda** en el cobro son los **Módulos** a los que se afilia la unidad.</p>
                    </div>

                    <h2>2. Gestión de Convivencia (Vehículos y Mascotas)</h2>
                    <p>La unidad es el centro de datos de la administración. Aquí se centraliza la información que va más allá de lo contable:</p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-8">
                        <div class="p-8 bg-blue-50 rounded-3xl">
                            <h4 class="font-bold text-blue-700 mb-2">Vehículos</h4>
                            <p class="text-sm">Control de Placas, Marcas y parqueaderos asignados.</p>
                        </div>
                        <div class="p-8 bg-indigo-50 rounded-3xl">
                            <h4 class="font-bold text-indigo-700 mb-2">Mascotas</h4>
                            <p class="text-sm">Registro de razas y datos de sanidad para la convivencia segura.</p>
                        </div>
                    </div>
                </section>

                <!-- Capítulo 6 -->
                <section id="cap-6" class="chapter-content hidden">
                    <h1>Capítulo 6: Mapas Lógicos Avanzados</h1>
                    
                    <div class="premium-card">
                        <h2>1. El Flujo de Inteligencia Financiera</h2>
                        <p>Este mapa resume cómo el sistema transforma reglas de negocio en documentos contables.</p>
                        <div class="mermaid">
                        graph TD
                            C[Conceptos] --> M[Módulos]
                            T[Torres] --> U[Unidades]
                            M --> U
                            U --> F[Factura]
                            F --> K[Cartera 1305]
                            K --> B[Balance Real]
                        </div>
                    </div>

                    <div class="premium-card">
                        <h2>2. Ciclo de Cruce de Anticipos</h2>
                        <p>Visualización del proceso automatizado de saneamiento de cartera.</p>
                        <div class="mermaid">
                        flowchart LR
                            Factura --> Deuda[Cuenta 1305]
                            Anticipo[Cuenta 2805] --> Cruce{¿Hay saldo?}
                            Cruce -->|Sí| Deuda
                            Deuda --> Resultado[Saldo Neto]
                        </div>
                    </div>

                    <div class="consultancy-note p-8 bg-gray-50 rounded-3xl border-l-8 border-indigo-600 mt-12">
                        <p class="m-0 text-sm italic font-medium">"La claridad visual es el primer paso para una administración libre de errores. Use estos diagramas para capacitar a su equipo contable."</p>
                    </div>
                </section>

                <!-- Footer Navigation -->
                <div class="mt-20 pt-10 border-t border-gray-100 flex justify-between items-center bg-white/50 p-8 rounded-[40px]">
                    <button id="prevBtn" onclick="changeStep(-1)" class="px-8 py-4 bg-white border border-gray-100 rounded-2xl text-md font-bold text-gray-300 transition-all opacity-50 cursor-not-allowed">Anterior</button>
                    
                    <div id="stepDots" class="flex gap-3">
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 dot-active cursor-pointer" onclick="showChapter(1)"></div>
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 cursor-pointer" onclick="showChapter(2)"></div>
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 cursor-pointer" onclick="showChapter(3)"></div>
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 cursor-pointer" onclick="showChapter(4)"></div>
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 cursor-pointer" onclick="showChapter(5)"></div>
                        <div class="dot w-3 h-3 rounded-full bg-gray-200 transition-all duration-500 cursor-pointer" onclick="showChapter(6)"></div>
                    </div>

                    <button id="nextBtn" onclick="changeStep(1)" class="px-10 py-4 bg-indigo-600 text-white rounded-2xl text-md font-bold hover:bg-indigo-700 shadow-xl shadow-indigo-100 transition-all">Siguiente</button>
                </div>
            </div>
        </main>
    </div>

    <script>
        mermaid.initialize({ 
            startOnLoad: true, 
            theme: 'base', 
            themeVariables: {
                primaryColor: '#EEF2FF',
                primaryTextColor: '#4F46E5',
                primaryBorderColor: '#4F46E5',
                lineColor: '#6366F1',
                secondaryColor: '#F8FAFC',
                tertiaryColor: '#FFFFFF',
                fontFamily: 'Outfit'
            },
            securityLevel: 'loose' 
        });

        let currentChapter = 1;
        const TOTAL_CHAPTERS = 6;

        function showChapter(n) {
            document.querySelectorAll('.chapter-content').forEach(el => {
                el.classList.add('hidden');
                el.classList.remove('block', 'visible');
            });
            
            setTimeout(() => {
                const target = document.getElementById(`cap-${n}`);
                if (target) {
                    target.classList.remove('hidden');
                    target.classList.add('block');
                    setTimeout(() => target.classList.add('visible'), 50);
                    // Force mermaid re-render
                    mermaid.run({ nodes: target.querySelectorAll('.mermaid') });
                }
            }, 300);
            
            document.querySelectorAll('.sidebar-item').forEach((el, index) => {
                if (index === n-1) {
                    el.classList.add('sidebar-item-active');
                    el.classList.replace('text-gray-400', 'text-gray-900');
                } else {
                    el.classList.remove('sidebar-item-active');
                    el.classList.add('text-gray-400');
                }
            });

            document.querySelectorAll('#stepDots .dot').forEach((el, index) => {
                if (index === n-1) {
                    el.classList.add('dot-active');
                } else {
                    el.classList.remove('dot-active');
                }
            });

            const prev = document.getElementById('prevBtn');
            const next = document.getElementById('nextBtn');
            
            prev.className = `px-8 py-4 bg-white border border-gray-200 rounded-2xl text-md font-bold transition-all ${n === 1 ? 'opacity-50 cursor-not-allowed text-gray-200' : 'hover:bg-gray-100 text-gray-700 shadow-sm'}`;
            next.innerText = n === TOTAL_CHAPTERS ? 'Cerrar' : 'Siguiente';
            next.className = `px-10 py-4 ${n === TOTAL_CHAPTERS ? 'bg-green-600 hover:bg-green-700' : 'bg-indigo-600 hover:bg-indigo-700'} text-white rounded-2xl text-md font-bold shadow-xl shadow-indigo-100 transition-all`;
            next.onclick = n === TOTAL_CHAPTERS ? () => window.close() : () => changeStep(1);

            currentChapter = n;
            document.getElementById('contentArea').scrollTo({ top: 0, behavior: 'smooth' });
        }

        function changeStep(dir) {
            let next = currentChapter + dir;
            if (next >= 1 && next <= TOTAL_CHAPTERS) {
                showChapter(next);
            }
        }

        window.onload = () => showChapter(1);
    </script>
</body>
</html>
